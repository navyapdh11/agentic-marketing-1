    "title": "Agentic ML Marketing v5.0.0",
    "tags": ["agentic-marketing", "ml", "istio"],
    "timezone": "Australia/Sydney",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "10s",
    "time": {"from": "now-6h", "to": "now"},
    "panels": [
      {"id":1,"title":"MAB Thompson Sampling ROI","type":"stat","gridPos":{"h":8,"w":6,"x":0,"y":0},
       "targets":[{"expr":"thompson_sampling_roi","legendFormat":"ROI"}]},
      {"id":2,"title":"MCTS Predicted ROI","type":"gauge","gridPos":{"h":8,"w":6,"x":6,"y":0},
       "targets":[{"expr":"mcts_predicted_roi","legendFormat":"Predicted ROI"}],
       "fieldConfig":{"defaults":{"min":0,"max":10,"thresholds":{"steps":[{"color":"red","value":null},{"color":"yellow","value":3},{"color":"green","value":5}]}}}},
      {"id":3,"title":"Total Agentic Actions","type":"stat","gridPos":{"h":8,"w":6,"x":12,"y":0},
       "targets":[{"expr":"agentic_actions_total","legendFormat":"Actions"}]},
      {"id":4,"title":"Semantic Memory Size","type":"stat","gridPos":{"h":8,"w":6,"x":18,"y":0},
       "targets":[{"expr":"semantic_memory_size","legendFormat":"Memories"}]},
      {"id":5,"title":"Channel Allocation (Thompson)","type":"graph","gridPos":{"h":8,"w":12,"x":0,"y":8},
       "targets":[{"expr":"thompson_channel_allocation","legendFormat":"{{channel}}"}]},
      {"id":6,"title":"MCTS Search Latency","type":"graph","gridPos":{"h":8,"w":12,"x":12,"y":8},
       "targets":[{"expr":"histogram_quantile(0.95, rate(mcts_search_duration_bucket[5m]))","legendFormat":"p95"}]},
      {"id":7,"title":"Redis Memory Usage","type":"graph","gridPos":{"h":8,"w":8,"x":0,"y":16},
       "targets":[{"expr":"redis_memory_used_bytes","legendFormat":"Used"}]},
      {"id":8,"title":"Prometheus Scrape Duration","type":"graph","gridPos":{"h":8,"w":8,"x":8,"y":16},
       "targets":[{"expr":"prometheus_target_interval_length_seconds{quantile=\"0.99\"}","legendFormat":"{{job}}"}]},
      {"id":9,"title":"Agentic Cycle Success Rate","type":"stat","gridPos":{"h":8,"w":8,"x":16,"y":16},
       "targets":[{"expr":"rate(agentic_cycle_success_total[5m])","legendFormat":"Rate"}]}
    ]
  },
  "overwrite": true,
  "message": "Agentic ML Marketing v5.0.0 Dashboard"
